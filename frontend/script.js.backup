// Auto-save functionality
function scheduleAutoSave() {
    if (autoSaveInterval) {
        clearTimeout(autoSaveInterval);
    }
    
    autoSaveInterval = setTimeout(function() {
        saveDraft();
    }, AUTOSAVE_INTERVAL);
}

function saveDraft() {
    if (editor) {
        const content = editor.getValue();
        if (content.trim()) {
            localStorage.setItem(AUTOSAVE_KEY, content);
            localStorage.setItem(AUTOSAVE_KEY + '_timestamp', Date.now());
        }
    }
}

function loadDraft() {
    const savedContent = localStorage.getItem(AUTOSAVE_KEY);
    const timestamp = localStorage.getItem(AUTOSAVE_KEY + '_timestamp');
    
    if (savedContent && timestamp) {
        const age = Date.now() - parseInt(timestamp);
        const ageHours = age / (1000 * 60 * 60);
        
        // Only load drafts that are less than 24 hours old
        if (ageHours < 24) {
            setTimeout(function() {
                if (editor && !editor.getValue().trim()) {
                    if (confirm('A draft was found. Would you like to restore it?')) {
                        editor.setValue(savedContent);
                        if (previewVisible) {
                            updatePreview();
                        }
                    }
                }
            }, 100);
        }
    }
}

function clearAutoSave() {
    localStorage.removeItem(AUTOSAVE_KEY);
    localStorage.removeItem(AUTOSAVE_KEY + '_timestamp');
}

// Override the original convertText function to use CodeMirror content
function convertText(format) {
    let markdownText;
    
    if (editor) {
        markdownText = editor.getValue();
    } else {
        markdownText = document.getElementById('markdownText').value;
    }
    
    if (!markdownText.trim()) {
        showMessage('Please enter some markdown text to convert.', 'error');
        return;
    }

    showLoading('Converting your text to ' + format.toUpperCase() + '...');

    // Get advanced options using the same function as preview
    const options = getAdvancedOptions();

    const endpoint = format === 'pdf' ? '/convert-pdf' : '/convert-text-advanced';

    fetch(endpoint, {
        method: 'POST',
        headers: {
            'Content-Type': 'application/json',
        },
        body: JSON.stringify({
            markdown: markdownText,
            options: options
        })
    })
    .then(response => {
        if (!response.ok) {
            return response.json().then(err => {
                throw new Error(err.error || `HTTP error! status: ${response.status}`);
            });
        }
        
        const contentType = response.headers.get('content-type');
        if (contentType && contentType.includes('application/json')) {
            return response.json().then(data => {
                throw new Error(data.error || 'Unknown error occurred');
            });
        }
        
        return response.blob();
    })
    .then(blob => {
        hideLoading();
        const url = window.URL.createObjectURL(blob);
        const a = document.createElement('a');
        a.href = url;
        const filename = getCustomFilename() || "converted_document";
        a.download = `${filename}.${format}`;
        document.body.appendChild(a);
        a.click();
        window.URL.revokeObjectURL(url);
        document.body.removeChild(a);
        showMessage('Your document has been converted and downloaded successfully!', 'success');
    })
    .catch(error => {
        hideLoading();
        console.error('Conversion error:', error);
        showMessage('Error converting document: ' + error.message, 'error');
    });
}

// switchMode function is defined earlier in the file

// Enhanced drag and drop for upload area
function initializeUploadArea() {
    const uploadArea = document.getElementById('uploadArea');
    const fileInput = document.getElementById('fileInput');
    
    if (!uploadArea || !fileInput) return;
    
    // Handle click to open file dialog
    uploadArea.addEventListener('click', function(e) {
        if (e.target !== fileInput && !e.target.closest('button')) {
            fileInput.click();
        }
    });
    
    // Enhanced drag and drop
    uploadArea.addEventListener('dragover', function(e) {
        e.preventDefault();
        uploadArea.classList.add('drag-over');
    });
    
    uploadArea.addEventListener('dragleave', function(e) {
        e.preventDefault();
        // Only remove drag-over if we're actually leaving the upload area
        if (!uploadArea.contains(e.relatedTarget)) {
            uploadArea.classList.remove('drag-over');
        }
    });
    
    uploadArea.addEventListener('drop', function(e) {
        e.preventDefault();
        uploadArea.classList.remove('drag-over');
        
        const files = e.dataTransfer.files;
        if (files.length > 0) {
            fileInput.files = files;
            
            // Show file count feedback
            const fileCount = files.length;
            const fileText = fileCount === 1 ? 'file' : 'files';
            showMessage(`${fileCount} ${fileText} selected for upload`, 'success');
        }
    });
    
    // File input change handler
    fileInput.addEventListener('change', function() {
        const fileCount = fileInput.files.length;
        if (fileCount > 0) {
            const fileText = fileCount === 1 ? 'file' : 'files';
            showMessage(`${fileCount} ${fileText} selected`, 'success');
        }
    });
}

// Initialize on DOM load
document.addEventListener('DOMContentLoaded', function() {
    initializeEditor();
    loadDraft();
    initializeUploadArea();
    initializeAdvancedOptionsListeners();
    initializePreviewOverlayListeners();
    
    // Set default mode to editor
    switchMode('editor');
});

// Initialize preview overlay event listeners
function initializePreviewOverlayListeners() {
    const previewOverlay = document.getElementById('previewOverlay');
    const previewModal = document.getElementById('previewModal');
    const closeButton = document.getElementById('previewCloseButton');
    
    // Close when clicking the close button
    if (closeButton) {
        closeButton.addEventListener('click', closePreview);
    }
    
    // Close when clicking outside the modal
    if (previewOverlay) {
        previewOverlay.addEventListener('click', function(e) {
            if (e.target === previewOverlay) {
                closePreview();
            }
        });
    }
    
    // Close with Escape key
    document.addEventListener('keydown', function(e) {
        if (e.key === 'Escape' && previewVisible) {
            closePreview();
        }
    });
}

// Initialize advanced options event listeners
function initializeAdvancedOptionsListeners() {
    // Add event listeners to all advanced option controls
    const optionIds = ['enableToc', 'numberedSections', 'customHeader', 'customFooter'];
    
    optionIds.forEach(id => {
        const element = document.getElementById(id);
        if (element) {
            if (element.type === 'checkbox') {
                element.addEventListener('change', function() {
                    if (previewVisible) {
                        updatePreview();
                    }
                });
            } else {
                // For text inputs, add both input and change listeners
                element.addEventListener('input', function() {
                    if (previewVisible) {
                        // Debounce the update for text inputs
                        clearTimeout(element.updateTimeout);
                        element.updateTimeout = setTimeout(() => {
                            updatePreview();
                        }, 500);
                    }
                });
                
                element.addEventListener('change', function() {
                    if (previewVisible) {
                        updatePreview();
                    }
                });
            }
        }
    });
}

// Make new functions globally available
window.togglePreview = togglePreview;
window.clearEditor = clearEditor;
window.loadSample = loadSample;
window.convertText = convertText;
// switchMode is already available globally