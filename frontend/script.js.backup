// Loading state management
function showLoading(message = "Converting your document...") {
    const overlay = document.getElementById('loadingOverlay');
    const loadingText = overlay.querySelector('.loading-text');
    loadingText.textContent = message;
    overlay.classList.add('active');
    
    // Disable all buttons during loading
    document.querySelectorAll('.btn').forEach(btn => btn.disabled = true);
}

function hideLoading() {
    document.getElementById('loadingOverlay').classList.remove('active');
    
    // Re-enable all buttons
    document.querySelectorAll('.btn').forEach(btn => btn.disabled = false);
}

// Message display
function showMessage(text, type = 'error') {
    const messageEl = document.getElementById('message');
    messageEl.textContent = text;
    messageEl.className = type;
    
    // Auto-clear message after 5 seconds
    setTimeout(() => {
        messageEl.textContent = '';
        messageEl.className = '';
    }, 5000);
}

async function uploadFileAdvanced() {
    const fileInput = document.getElementById('fileInput');
    
    if (!fileInput.files.length) {
        showMessage("Please select one or more files", "warning");
        return;
    }
    
    const files = Array.from(fileInput.files);
    const validExtensions = ['.md', '.markdown', '.txt'];
    const maxFileSize = 10 * 1024 * 1024; // 10MB per file
    
    // Validate all files
    for (const file of files) {
        const fileName = file.name.toLowerCase();
        const hasValidExtension = validExtensions.some(ext => fileName.endsWith(ext));
        
        if (!hasValidExtension) {
            showMessage(`Invalid file type: ${file.name}. Please upload only .md, .markdown, or .txt files`, "error");
            return;
        }
        
        if (file.size > maxFileSize) {
            showMessage(`File too large: ${file.name}. Maximum size is 10MB per file`, "error");
            return;
        }
    }
    
    // Handle single file vs batch processing
    if (files.length === 1) {
        await processSingleFile(files[0]);
    } else {
        await processBatchFiles(files);
    }
    
    fileInput.value = ''; // Clear file input
}

async function processSingleFile(file) {
    const formData = new FormData();
    formData.append("file", file);
    
    const options = getAdvancedOptions();
    formData.append("options", JSON.stringify(options));
    
    showLoading("Converting " + file.name + " to DOCX...");

    try {
        const response = await fetch('/convert-advanced', {
            method: 'POST',
            body: formData
        });

        if (response.ok) {
            await handleResponse(response, file.name.replace(/\.(md|markdown|txt)$/i, '.docx'));
            showMessage("File converted successfully!", "success");
        } else {
            const error = await response.json();
            showMessage(error.error || "Conversion failed", "error");
        }
    } catch (error) {
        console.error("Upload error:", error);
        showMessage("Network error. Please check your connection and try again.", "error");
    } finally {
        hideLoading();
    }
}

async function processBatchFiles(files) {
    const formData = new FormData();
    
    // Append all files
    files.forEach(file => {
        formData.append("files", file);
    });
    
    const options = getAdvancedOptions();
    formData.append("options", JSON.stringify(options));
    
    const fileNames = files.map(f => f.name).join(", ");
    showLoading(`Converting ${files.length} files to DOCX...`);

    try {
        const response = await fetch('/convert-batch', {
            method: 'POST',
            body: formData
        });

        if (response.ok) {
            const timestamp = new Date().toISOString().slice(0, 16).replace(/[-:T]/g, '');
            await handleResponse(response, `converted_files_${timestamp}.zip`);
            showMessage(`Successfully converted ${files.length} files!`, "success");
        } else {
            const error = await response.json();
            showMessage(error.error || "Batch conversion failed", "error");
        }
    } catch (error) {
        console.error("Batch upload error:", error);
        showMessage("Network error. Please check your connection and try again.", "error");
    } finally {
        hideLoading();
    }
}

// getAdvancedOptions function is defined later in the file with proper error handling

async function convertText(format) {
    const markdownText = document.getElementById('markdownText').value.trim();
    
    if (!markdownText) {
        showMessage("Please enter Markdown text", "warning");
        return;
    }
    
    // Check text size (approximate - 1 char ≈ 1 byte for ASCII)
    if (markdownText.length > 10 * 1024 * 1024) {
        showMessage("Text too large. Please reduce the content size.", "error");
        return;
    }

    // Collect advanced options
    const options = getAdvancedOptions();
    
    const endpoint = format === "pdf" ? "/convert-pdf" : "/convert-text-advanced";
    const loadingMessage = format === "pdf" ? "Converting to PDF..." : "Converting to DOCX with advanced options...";
    
    showLoading(loadingMessage);
    
    try {
        const payload = { 
            markdown: markdownText,
            options: options
        };
        
        const response = await fetch(endpoint, {
            method: 'POST',
            headers: { "Content-Type": "application/json" },
            body: JSON.stringify(payload)
        });

        if (response.ok) {
            const filename = getCustomFilename() || "converted";
            await handleResponse(response, `${filename}.${format}`);
            showMessage(`Successfully converted to ${format.toUpperCase()}!`, "success");
        } else {
            const error = await response.json();
            showMessage(error.error || "Conversion failed", "error");
        }
    } catch (error) {
        console.error("Conversion error:", error);
        showMessage("Network error. Please check your connection and try again.", "error");
    } finally {
        hideLoading();
    }
}

async function saveMdFile() {
    const markdownText = document.getElementById('markdownText').value.trim();
    
    if (!markdownText) {
        showMessage("Please enter Markdown text", "warning");
        return;
    }
    
    // Check text size
    if (markdownText.length > 10 * 1024 * 1024) {
        showMessage("Text too large. Please reduce the content size.", "error");
        return;
    }
    
    showLoading("Saving as Markdown file...");

    try {
        const response = await fetch('/save-md', {
            method: 'POST',
            headers: { "Content-Type": "application/json" },
            body: JSON.stringify({ markdown: markdownText })
        });

        if (response.ok) {
            const filename = getCustomFilename() || "document";
            await handleResponse(response, `${filename}.md`);
            showMessage("Markdown file saved successfully!", "success");
        } else {
            const error = await response.json();
            showMessage(error.error || "Failed to save file", "error");
        }
    } catch (error) {
        console.error("Save error:", error);
        showMessage("Network error. Please check your connection and try again.", "error");
    } finally {
        hideLoading();
    }
}

async function handleResponse(response, filename) {
    try {
        const blob = await response.blob();
        const downloadLink = document.createElement('a');
        downloadLink.href = URL.createObjectURL(blob);
        downloadLink.download = filename;
        document.body.appendChild(downloadLink);
        downloadLink.click();
        document.body.removeChild(downloadLink);
        
        // Clean up the object URL after download
        setTimeout(() => {
            URL.revokeObjectURL(downloadLink.href);
        }, 100);
    } catch (error) {
        console.error("Download error:", error);
        showMessage("Failed to download file", "error");
    }
}

// Add keyboard shortcuts
document.addEventListener('DOMContentLoaded', () => {
    // Ctrl/Cmd + Enter to convert text
    document.getElementById('markdownText').addEventListener('keydown', (e) => {
        if ((e.ctrlKey || e.metaKey) && e.key === 'Enter') {
            convertText('docx');
        }
    });
    
    // Clear message on new input
    document.getElementById('markdownText').addEventListener('input', () => {
        const messageEl = document.getElementById('message');
        if (messageEl.textContent) {
            messageEl.textContent = '';
            messageEl.className = '';
        }
    });
    
    // Drag and drop support for file upload
    const container = document.querySelector('.container');
    
    container.addEventListener('dragover', (e) => {
        e.preventDefault();
        container.style.backgroundColor = '#e8f4f8';
    });
    
    container.addEventListener('dragleave', (e) => {
        e.preventDefault();
        container.style.backgroundColor = 'white';
    });
    
    container.addEventListener('drop', (e) => {
        e.preventDefault();
        container.style.backgroundColor = 'white';
        
        const files = e.dataTransfer.files;
        if (files.length > 0) {
            document.getElementById('fileInput').files = files;
            uploadFileAdvanced();
        }
    });
});

// Make functions globally available for onclick handlers
window.uploadFileAdvanced = uploadFileAdvanced;

// Mode switching functionality (must be available immediately)
function switchMode(mode) {
    const editorMode = document.getElementById('editorMode');
    const uploadMode = document.getElementById('uploadMode');
    const editorTab = document.getElementById('editorTab');
    const uploadTab = document.getElementById('uploadTab');
    
    // Hide all modes
    editorMode.style.display = 'none';
    uploadMode.style.display = 'none';
    
    // Remove active class from all tabs
    editorTab.classList.remove('active');
    uploadTab.classList.remove('active');
    
    // Show selected mode and mark tab as active
    if (mode === 'editor') {
        editorMode.style.display = 'block';
        editorTab.classList.add('active');
        
        // Initialize CodeMirror if not already done
        if (!editor) {
            setTimeout(function() {
                initializeEditor();
            }, 100);
        }
    } else if (mode === 'upload') {
        uploadMode.style.display = 'block';
        uploadTab.classList.add('active');
    }
}

// Make switchMode available immediately
window.switchMode = switchMode;

// Live Preview Editor Implementation
let editor = null;
let previewVisible = false;
let autoSaveInterval = null;
const AUTOSAVE_KEY = 'markdown_editor_draft';
const AUTOSAVE_INTERVAL = 2000; // 2 seconds

// This will be handled in the consolidated DOMContentLoaded listener below

function initializeEditor() {
    const textArea = document.getElementById('markdownText');
    if (!textArea || !window.CodeMirror) {
        console.error('CodeMirror not loaded or textarea not found');
        return;
    }
    
    editor = CodeMirror.fromTextArea(textArea, {
        mode: 'markdown',
        theme: 'github',
        lineNumbers: true,
        lineWrapping: true,
        placeholder: 'Start typing your markdown here...',
        extraKeys: {
            "Enter": "newlineAndIndentContinueMarkdownList",
            "Ctrl-/": toggleComment,
            "Cmd-/": toggleComment
        },
        autofocus: true,
        styleActiveLine: true,
        matchBrackets: true,
        dragDrop: true,
        allowDropFileTypes: ['text/plain', 'text/markdown']
    });
    
    // Set up real-time preview updates
    editor.on('change', function() {
        if (previewVisible) {
            updatePreview();
        }
        scheduleAutoSave();
    });
    
    // Handle paste events for better formatting
    editor.on('paste', function(cm, e) {
        scheduleAutoSave();
    });
}

function toggleComment(cm) {
    const cursor = cm.getCursor();
    const line = cm.getLine(cursor.line);
    const commentPrefix = '<!-- ';
    const commentSuffix = ' -->';
    
    if (line.trim().startsWith(commentPrefix) && line.trim().endsWith(commentSuffix)) {
        // Uncomment
        const newLine = line.replace(commentPrefix, '').replace(commentSuffix, '');
        cm.replaceRange(newLine, {line: cursor.line, ch: 0}, {line: cursor.line, ch: line.length});
    } else {
        // Comment
        const newLine = commentPrefix + line.trim() + commentSuffix;
        cm.replaceRange(newLine, {line: cursor.line, ch: 0}, {line: cursor.line, ch: line.length});
    }
}

function togglePreview() {
    const previewOverlay = document.getElementById('previewOverlay');
    const toggleButton = document.getElementById('previewToggle');
    
    if (previewVisible) {
        closePreview();
    } else {
        showPreview();
    }
}

function showPreview() {
    const previewOverlay = document.getElementById('previewOverlay');
    const toggleButton = document.getElementById('previewToggle');
    
    previewOverlay.classList.add('show');
    toggleButton.textContent = 'Hide Preview';
    previewVisible = true;
    updatePreview();
    
    // Prevent body scrolling when overlay is open
    document.body.style.overflow = 'hidden';
}

function closePreview() {
    const previewOverlay = document.getElementById('previewOverlay');
    const toggleButton = document.getElementById('previewToggle');
    
    previewOverlay.classList.remove('show');
    toggleButton.textContent = 'Show Preview';
    previewVisible = false;
    
    // Restore body scrolling
    document.body.style.overflow = '';
}

function updatePreview() {
    if (!editor || !previewVisible) return;
    
    const markdownContent = editor.getValue();
    const previewElement = document.getElementById('markdownPreview');
    
    if (!markdownContent.trim()) {
        previewElement.innerHTML = '<p><em>Start typing to see the preview...</em></p>';
        return;
    }
    
    try {
        // Get advanced options
        const options = getAdvancedOptions();
        
        // Configure marked with GitHub-style options
        const markedOptions = {
            breaks: true,
            gfm: true,
            sanitize: false,
            smartypants: true,
            highlight: function(code, lang) {
                return '<pre><code>' + escapeHtml(code) + '</code></pre>';
            }
        };
        
        marked.setOptions(markedOptions);
        
        // Process markdown content with advanced options
        let processedContent = markdownContent;
        
        // Add custom headers/footers if enabled
        if (options.customHeader || options.customFooter) {
            processedContent = addHeadersFootersToPreview(processedContent, options);
        }
        
        let html = marked.parse(processedContent);
        
        // Apply Table of Contents if enabled
        if (options.enableToc) {
            html = addTableOfContents(html);
        }
        
        // Apply numbered sections if enabled
        if (options.numberedSections) {
            html = addNumberedSections(html);
        }
        
        // Syntax highlighting removed from options
        
        previewElement.innerHTML = html;
        
        // Show preview options indicator
        showPreviewOptionsIndicator(options);
        
    } catch (error) {
        previewElement.innerHTML = '<p><em>Error rendering preview: ' + error.message + '</em></p>';
        console.error('Preview error:', error);
    }
}

function escapeHtml(text) {
    const div = document.createElement('div');
    div.textContent = text;
    return div.innerHTML;
}

function getCustomFilename() {
    const filenameInput = document.getElementById('documentFilename');
    if (!filenameInput) return null;
    
    const filename = filenameInput.value.trim();
    if (!filename) return null;
    
    // Remove any file extensions and invalid characters
    return filename.replace(/\.(docx|md|pdf)$/i, '').replace(/[<>:"/\\|?*]/g, '');
}

// Helper function to get all advanced options
function getAdvancedOptions() {
    return {
        enableToc: document.getElementById('enableToc')?.checked || false,
        numberedSections: document.getElementById('numberedSections')?.checked || false,
        customHeader: document.getElementById('customHeader')?.value || '',
        customFooter: document.getElementById('customFooter')?.value || ''
    };
}

// Add custom headers/footers to preview
function addHeadersFootersToPreview(content, options) {
    let previewContent = content;
    
    if (options.customHeader) {
        previewContent = `<div class="document-header">${escapeHtml(options.customHeader)}</div>\n\n` + previewContent;
    }
    
    if (options.customFooter) {
        previewContent = previewContent + `\n\n<div class="document-footer">${escapeHtml(options.customFooter)}</div>`;
    }
    
    return previewContent;
}

// Generate table of contents
function addTableOfContents(html) {
    const headings = [];
    const tocRegex = /<(h[1-6])[^>]*>(.*?)<\/h[1-6]>/gi;
    let match;
    let headingIndex = 0;
    
    // Extract headings and add IDs
    let processedHtml = html.replace(tocRegex, (fullMatch, tag, content) => {
        headingIndex++;
        const level = parseInt(tag.charAt(1));
        const headingId = `heading-${headingIndex}`;
        const cleanContent = content.replace(/<[^>]*>/g, ''); // Remove any HTML tags
        
        headings.push({
            level: level,
            content: cleanContent,
            id: headingId
        });
        
        return `<${tag} id="${headingId}">${content}</${tag}>`;
    });
    
    if (headings.length === 0) {
        return html; // No headings found
    }
    
    // Generate TOC HTML
    let tocHtml = '<div class="table-of-contents">\n<h2>Table of Contents</h2>\n<ul class="toc-list">\n';
    
    headings.forEach(heading => {
        const indent = '  '.repeat(heading.level - 1);
        tocHtml += `${indent}<li class="toc-level-${heading.level}"><a href="#${heading.id}">${heading.content}</a></li>\n`;
    });
    
    tocHtml += '</ul>\n</div>\n\n';
    
    return tocHtml + processedHtml;
}

// Add numbered sections
function addNumberedSections(html) {
    const counters = [0, 0, 0, 0, 0, 0]; // For h1-h6
    
    return html.replace(/<(h[1-6])[^>]*>(.*?)<\/h[1-6]>/gi, (match, tag, content) => {
        const level = parseInt(tag.charAt(1)) - 1;
        
        // Reset deeper level counters
        for (let i = level + 1; i < counters.length; i++) {
            counters[i] = 0;
        }
        
        // Increment current level counter
        counters[level]++;
        
        // Build numbering
        const numbering = counters.slice(0, level + 1).filter(n => n > 0).join('.');
        
        return `<${tag}><span class="section-number">${numbering}.</span> ${content}</${tag}>`;
    });
}

// Apply syntax highlighting styles
function applySyntaxHighlighting(html) {
    // Add enhanced syntax highlighting styles
    return html.replace(/<pre class="hljs language-([^"]*)">/g, 
        '<pre class="hljs language-$1" style="background-color: #f8f8f8; padding: 16px; border-radius: 6px; border-left: 4px solid #0366d6;">');
}

// Show preview options indicator
function showPreviewOptionsIndicator(options) {
    // Remove existing indicator
    const existingIndicator = document.querySelector('.preview-options-indicator');
    if (existingIndicator) {
        existingIndicator.remove();
    }
    
    // Create new indicator if any options are enabled
    const enabledOptions = [];
    if (options.enableToc) enabledOptions.push('Table of Contents');
    if (options.numberedSections) enabledOptions.push('Numbered Sections');
    if (options.customHeader) enabledOptions.push('Custom Header');
    if (options.customFooter) enabledOptions.push('Custom Footer');
    
    if (enabledOptions.length === 0) return;
    
    const indicator = document.createElement('div');
    indicator.className = 'preview-options-indicator';
    indicator.innerHTML = `
        <div class="options-badge">
            <span class="badge-icon">⚙️</span>
            <span class="badge-text">Preview with: ${enabledOptions.join(', ')}</span>
        </div>
    `;
    
    const previewContent = document.getElementById('markdownPreview');
    previewContent.appendChild(indicator);
}

function clearEditor() {
    if (editor) {
        if (confirm('Are you sure you want to clear the editor? This action cannot be undone.')) {
            editor.setValue('');
            updatePreview();
            clearAutoSave();
        }
    }
}

