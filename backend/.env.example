# Flask Configuration
FLASK_ENV=development
FLASK_DEBUG=1
HOST=0.0.0.0
PORT=5000
LOG_LEVEL=INFO

# File Handling
UPLOAD_FOLDER=uploads
OUTPUT_FOLDER=outputs
MAX_FILE_SIZE=10485760  # 10MB in bytes
ALLOWED_EXTENSIONS=md,markdown,txt
FILE_CLEANUP_ENABLED=1
FILE_CLEANUP_INTERVAL=3600
FILE_MAX_AGE=86400

# Rate Limiting
RATE_LIMIT_DEFAULT=100 per day
RATE_LIMIT_UPLOADS=10 per hour
RATE_LIMIT_TEXT=20 per hour

# CORS Configuration
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5000,https://yourdomain.com

# Optional: Clerk Integration
# CLERK_ENDPOINT=https://your-tenant.clerk.accounts.com
# CLERK_AUDIENCE=your_clerk_app_id
